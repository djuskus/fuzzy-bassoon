default_platform(:ios)

platform :ios do
  desc "Sync/create certificates and profiles (run this first to initialise match)"
  lane :certs do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY_BASE64"],
      is_key_content_base64: true
    )
    match(type: "appstore", api_key: api_key)
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY_BASE64"],
      is_key_content_base64: true
    )

    match(type: "appstore", readonly: true, api_key: api_key)

    sh("flutter build ios --release --no-codesign")

    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.ultaire.blessedreadings" => "match AppStore com.ultaire.blessedreadings"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
